# Supabase — get from https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude Agent SDK — run: claude setup-token
# Uses your Max subscription — $0 per-token cost (local dev only)
CLAUDE_CODE_OAUTH_TOKEN=your-claude-oauth-token

# Anthropic Direct API — REQUIRED for Vercel deployment
# Agent SDK can't run on serverless — this key enables direct Claude API calls
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI — GPT-5 Nano for light tasks
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# Telegram Bot
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_LINK_SECRET=your-link-secret

# ngrok static domain — get yours free at https://dashboard.ngrok.com/domains
# Set this once and your Telegram webhook URL never changes.
NGROK_DOMAIN=your-subdomain.ngrok-free.app
